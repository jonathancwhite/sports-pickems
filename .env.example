# Database
# Runtime connection string for API and worker. Use Supabase pooler (port 6543) in production.
DATABASE_URL=postgresql://callsheet:callsheet@localhost:5432/callsheet
# Direct connection for migrations (`pnpm db:migrate`). Falls back to DATABASE_URL when unset.
DATABASE_URL_DIRECT=postgresql://callsheet:callsheet@localhost:5432/callsheet

# Clerk authentication and billing
# Secret key for API server-side auth (never expose to the browser)
CLERK_SECRET_KEY=
# Publishable key for Clerk frontend components
CLERK_PUBLISHABLE_KEY=
# Webhook signing secret from Clerk Dashboard → Webhooks
CLERK_WEBHOOK_SECRET=

# API server
PORT=3001
# Shared secret for GitHub Actions cron jobs hitting /api/cron/*
CRON_SECRET=
NODE_ENV=development
# Allowed CORS origin — set to production web URL in Netlify/Fly env
WEB_URL=http://localhost:5173

# Resend transactional email
RESEND_API_KEY=
# Verified sender domain in Resend (e.g. noreply@callsheet.app)
EMAIL_FROM=noreply@callsheet.app

# Web app (Vite — only VITE_* vars are exposed to the browser)
VITE_API_URL=http://localhost:3001
VITE_CLERK_PUBLISHABLE_KEY=
VITE_APP_NAME=Callsheet
VITE_APP_URL=http://localhost:5173
